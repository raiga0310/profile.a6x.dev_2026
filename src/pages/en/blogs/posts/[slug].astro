---
import PostLayout from '../../../../layouts/PostLayout.astro';
import { getCollection, render } from 'astro:content';
import { isLocale, toSlug } from '../../../../i18n';

export async function getStaticPaths() {
  const posts = await getCollection('posts', p => !p.data.draft && isLocale(p.id, 'en'));
  return posts.map(p => ({
    params: { slug: toSlug(p.id) },
    props: { post: p },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const slug = toSlug(post.id);
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  publishedAt={post.data.publishedAt}
  tags={post.data.tags}
  ogImage={`/og/posts/${slug}.png`}
  lang="en"
  aiInvolvement={post.data.aiInvolvement}
>
  <Content />
</PostLayout>
