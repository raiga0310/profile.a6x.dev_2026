---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 Not Found | a6x.dev">
  <div class="container" style="padding: 6rem 1.5rem; text-align: center;">
    <h1 style="font-size: 5rem; font-weight: 800; color: var(--border); margin-bottom: 1rem;">404</h1>
    <p style="font-size: 1.2rem; color: var(--text-muted); margin-bottom: 2rem;">
      ページが見つかりませんでした。
    </p>
    <a href="/" style="color: var(--accent); font-size: 1rem;">← ホームに戻る</a>
  </div>
</BaseLayout>
