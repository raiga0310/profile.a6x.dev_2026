---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  lang?: string;
}

const {
  title = 'raiga | a6x.dev',
  description = 'raigaのポートフォリオサイト',
  ogImage = '/favicon.png',
  lang = 'ja',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const { pathname } = Astro.url;
const jaHref = new URL(pathname.startsWith('/en') ? pathname.replace(/^\/en/, '') || '/' : pathname, Astro.site);
const enHref = new URL(pathname.startsWith('/en') ? pathname : `/en${pathname}`, Astro.site);
const locale = (lang === 'en' ? 'en' : 'ja') as 'ja' | 'en';
---

<!doctype html>
<html lang={lang}>
  <head>
    <script is:inline>
      (function() {
        var stored = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        document.documentElement.setAttribute('data-theme', stored != null ? stored : (prefersDark ? 'dark' : 'light'));
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="ja" href={jaHref} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="x-default" href={jaHref} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </head>
  <body>
    <Nav locale={locale} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
