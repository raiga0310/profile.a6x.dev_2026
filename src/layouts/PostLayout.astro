---
import BaseLayout from './BaseLayout.astro';
import AiInvolvement from '../components/AiInvolvement.astro';

type AiLevel = 'none' | 'human' | 'ai';

interface Props {
  title: string;
  description?: string;
  publishedAt?: string;
  tags?: string[];
  ogImage?: string;
  lang?: string;
  aiInvolvement?: {
    planning?: AiLevel;
    writing?: AiLevel;
    review?: AiLevel;
    proofreading?: AiLevel;
  };
}

const { title, description, publishedAt, tags, ogImage, lang = 'ja', aiInvolvement } = Astro.props;
const dateLocale = lang === 'en' ? 'en-US' : 'ja-JP';
---

<BaseLayout title={`${title} | a6x.dev`} description={description} ogImage={ogImage} lang={lang}>
  <article class="post container">
    <header class="post__header">
      <h1 class="post__title">{title}</h1>
      {publishedAt && (
        <time class="post__date" datetime={publishedAt}>
          {new Date(publishedAt).toLocaleDateString(dateLocale, { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      )}
      {tags && tags.length > 0 && (
        <div class="post__tags">
          {tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      )}
    </header>
    {aiInvolvement && (
      <AiInvolvement
        planning={aiInvolvement.planning}
        writing={aiInvolvement.writing}
        review={aiInvolvement.review}
        proofreading={aiInvolvement.proofreading}
      />
    )}
    <div class="post__body prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .post {
    padding: 3rem 1.5rem;
  }

  .post__header {
    margin-bottom: 3rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .post__title {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  .post__date {
    font-size: 0.875rem;
    color: var(--text-muted);
    display: block;
    margin-bottom: 0.75rem;
  }

  .post__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .prose :global(h2),
  .prose :global(h3) {
    scroll-margin-top: calc(var(--nav-h) + 0.75rem);
  }
  .prose :global(h2) { font-size: 1.5rem; margin: 2rem 0 1rem; }
  .prose :global(h3) { font-size: 1.2rem; margin: 1.5rem 0 0.75rem; }

  .prose :global(.heading-anchor) {
    opacity: 0;
    margin-left: 0.4em;
    color: var(--text-muted);
    font-weight: 400;
    font-size: 0.8em;
    text-decoration: none;
    vertical-align: middle;
    transition: opacity 0.15s;
    user-select: none;
  }
  .prose :global(h2:hover .heading-anchor),
  .prose :global(h3:hover .heading-anchor) {
    opacity: 1;
  }
  .prose :global(h2:hover .heading-anchor:hover),
  .prose :global(h3:hover .heading-anchor:hover) {
    color: var(--accent);
  }
  .prose :global(p) { margin-bottom: 1rem; }
  .prose :global(ul), .prose :global(ol) { padding-left: 1.5rem; margin-bottom: 1rem; }
  .prose :global(li) { margin-bottom: 0.25rem; }
  .prose :global(pre) {
    background: #f4f4f4;
    border-radius: 6px;
    padding: 1rem;
    overflow-x: auto;
    margin-bottom: 1rem;
  }
  .prose :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
    color: var(--text-muted);
    margin: 1rem 0;
  }
</style>
