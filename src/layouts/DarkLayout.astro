---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import '../styles/slides-dark.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  lang?: string;
}

const {
  title = 'Slides | a6x.dev',
  description = 'raigaのスライド一覧',
  ogImage,
  lang = 'ja',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const { pathname } = Astro.url;
const jaHref = new URL(pathname.startsWith('/en') ? pathname.replace(/^\/en/, '') || '/' : pathname, Astro.site);
const enHref = new URL(pathname.startsWith('/en') ? pathname : `/en${pathname}`, Astro.site);
const locale = (lang === 'en' ? 'en' : 'ja') as 'ja' | 'en';
---

<!doctype html>
<html lang={lang} class="slides-theme">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="ja" href={jaHref} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="x-default" href={jaHref} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    {ogImage && <meta property="og:image" content={new URL(ogImage, Astro.site).href} />}
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    {ogImage && <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />}
    <!-- HackGen Console はシステムフォントとして利用、なければ JetBrains Mono にフォールバック -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <!-- Noto Sans JP: Meiryo / Yu Gothic UI のウェブフォントフォールバック -->
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Nav locale={locale} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
