---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__left">
      <p class="footer__copy">© {year} raiga</p>
      <p class="footer__note">Built with <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> using <a href="https://claude.ai/code" target="_blank" rel="noopener">Claude Code</a></p>
    </div>
    <div class="footer__links">
      <a href="https://github.com/raiga0310" target="_blank" rel="noopener">GitHub</a>
      <a href="https://zenn.dev/raiga" target="_blank" rel="noopener">Zenn</a>
      <a href="https://qiita.com/raiga" target="_blank" rel="noopener">Qiita</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border, #e0e0e0);
    padding: 1.5rem 0;
    margin-top: auto;
  }

  .footer__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer__left {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .footer__copy {
    font-size: 0.85rem;
    color: var(--text-muted, #666);
  }

  .footer__note {
    font-size: 0.75rem;
    color: var(--text-muted, #666);
  }

  .footer__note a {
    color: var(--text-muted, #666);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .footer__note a:hover {
    color: var(--accent, #4a6cf7);
  }

  .footer__links {
    display: flex;
    gap: 1.5rem;
  }

  .footer__links a {
    font-size: 0.85rem;
    color: var(--text-muted, #666);
    text-decoration: none;
  }

  .footer__links a:hover {
    color: var(--accent, #4a6cf7);
  }

  :global(.slides-theme) .footer {
    border-top-color: var(--slides-border);
  }

  :global(.slides-theme) .footer__copy,
  :global(.slides-theme) .footer__note,
  :global(.slides-theme) .footer__note a,
  :global(.slides-theme) .footer__links a {
    color: var(--slides-muted);
  }

  :global(.slides-theme) .footer__links a:hover {
    color: var(--slides-accent);
  }
</style>
