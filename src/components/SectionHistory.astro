---
const history = [
  {
    period: '2024年〜現在',
    title: 'ソフトウェアエンジニア',
    desc: 'Web バックエンド開発・API設計・インフラ構築',
  },
  {
    period: '2022年〜2024年',
    title: '学生エンジニア / インターン',
    desc: '複数のスタートアップにてインターンシップ、OSS 活動',
  },
  {
    period: '2020年〜2022年',
    title: 'プログラミング学習開始',
    desc: 'Rust・TypeScript を独学。競技プログラミング、個人開発に取り組む',
  },
];
---

<section class="section bg-alt" id="history">
  <div class="container">
    <h2 class="section-title">History</h2>
    <ol class="timeline">
      {history.map((item, i) => (
        <li class="timeline__item">
          <div class="timeline__dot" aria-hidden="true"></div>
          <div class="timeline__content">
            <span class="timeline__period">{item.period}</span>
            <h3 class="timeline__title">{item.title}</h3>
            <p class="timeline__desc">{item.desc}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .bg-alt {
    background: var(--surface);
  }

  .timeline {
    list-style: none;
    position: relative;
    padding-left: 2rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 0.4rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 2px;
    background: var(--border);
  }

  .timeline__item {
    position: relative;
    padding-bottom: 2.5rem;
  }

  .timeline__item:last-child {
    padding-bottom: 0;
  }

  .timeline__dot {
    position: absolute;
    left: -1.65rem;
    top: 0.35rem;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--accent);
    border: 2px solid var(--surface);
    box-shadow: 0 0 0 2px var(--accent);
  }

  .timeline__period {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .timeline__title {
    font-size: 1.05rem;
    margin: 0.25rem 0 0.4rem;
  }

  .timeline__desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
  }
</style>
