---
const history = [
  {
    period: '2025年8月〜2025年9月',
    title: 'Sansan株式会社 サマーインターン',
    desc: '技術本部 Data Intelligence EU MasterData グループにてインターン',
    type: 'intern',
  },
  {
    period: '2023年10月〜',
    title: '株式会社PR TIMES 開発本部 長期インターン',
    desc: 'PHPによるバックエンド開発。PHPStan・PHPUnit・BigQuery等を活用',
    type: 'intern',
  },
  {
    period: '2023年4月〜',
    title: '名古屋工業大学 第一部情報工学科 知能情報分野',
    desc: '',
    type: 'academic',
  },
  {
    period: '2018年4月〜2023年3月',
    title: '豊田工業高等専門学校 情報工学科',
    desc: '寮生会班長（3年）、学生会執行部副会長（3・4年）',
    type: 'academic',
  },
  {
    period: '2003年3月10日',
    title: '生まれる',
    desc: '愛知県出身',
    type: 'life',
  },
];
---

<section class="section bg-alt" id="history">
  <div class="container">
    <h2 class="section-title">History</h2>
    <div class="timeline__legend">
      <span class="legend-item legend-item--intern">インターン</span>
      <span class="legend-item legend-item--academic">学業</span>
      <span class="legend-item legend-item--life">生活</span>
    </div>
    <ol class="timeline">
      {history.map((item) => (
        <li class="timeline__item">
          <div class={`timeline__dot timeline__dot--${item.type}`} aria-hidden="true"></div>
          <div class="timeline__content">
            <span class="timeline__period">{item.period}</span>
            <h3 class="timeline__title">{item.title}</h3>
            {item.desc && <p class="timeline__desc">{item.desc}</p>}
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .bg-alt {
    background: var(--surface);
  }

  .timeline__legend {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .legend-item::before {
    content: '';
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .legend-item--intern::before { background: #f59e0b; }
  .legend-item--academic::before { background: var(--accent); }
  .legend-item--life::before { background: #a78bfa; }

  .timeline {
    list-style: none;
    position: relative;
    padding-left: 2rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 0.66rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 2px;
    background: var(--border);
  }

  .timeline__item {
    position: relative;
    padding-bottom: 2.5rem;
  }

  .timeline__item:last-child {
    padding-bottom: 0;
  }

  .timeline__dot {
    position: absolute;
    left: -1.55rem;
    top: 0.45rem;
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .timeline__dot--intern   { background: #f59e0b; }
  .timeline__dot--academic { background: var(--accent); }
  .timeline__dot--life     { background: #a78bfa; }

  .timeline__period {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .timeline__title {
    font-size: 1.05rem;
    margin: 0.25rem 0 0.4rem;
  }

  .timeline__desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
  }
</style>