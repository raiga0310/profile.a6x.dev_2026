---
const history = [
  {
    period: '2025年8月〜2025年9月',
    title: 'Sansan株式会社 サマーインターン',
    desc: '技術本部 Data Intelligence EU MasterData グループにてインターン',
  },
  {
    period: '2023年10月〜',
    title: '株式会社PR TIMES 開発本部 長期インターン',
    desc: 'PHPによるバックエンド開発。PHPStan・PHPUnit・BigQuery等を活用',
  },
  {
    period: '2023年4月〜',
    title: '名古屋工業大学 第一部情報工学科 知能情報分野',
    desc: '',
  },
  {
    period: '2018年4月〜2023年3月',
    title: '豊田工業高等専門学校 情報工学科',
    desc: '寮生会班長（3年）、学生会執行部副会長（3・4年）',
  },
  {
    period: '2003年3月10日',
    title: '生まれる',
    desc: '愛知県出身',
  },
];
---

<section class="section bg-alt" id="history">
  <div class="container">
    <h2 class="section-title">History</h2>
    <ol class="timeline">
      {history.map((item, i) => (
        <li class="timeline__item">
          <div class="timeline__dot" aria-hidden="true"></div>
          <div class="timeline__content">
            <span class="timeline__period">{item.period}</span>
            <h3 class="timeline__title">{item.title}</h3>
            <p class="timeline__desc">{item.desc}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .bg-alt {
    background: var(--surface);
  }

  .timeline {
    list-style: none;
    position: relative;
    padding-left: 2rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 0.66rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 2px;
    background: var(--border);
  }

  .timeline__item {
    position: relative;
    padding-bottom: 2.5rem;
  }

  .timeline__item:last-child {
    padding-bottom: 0;
  }

  .timeline__dot {
    position: absolute;
    left: -1.55rem;
    top: 0.45rem;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    border: none;
    box-shadow: none;
  }

  .timeline__period {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .timeline__title {
    font-size: 1.05rem;
    margin: 0.25rem 0 0.4rem;
  }

  .timeline__desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
  }
</style>
