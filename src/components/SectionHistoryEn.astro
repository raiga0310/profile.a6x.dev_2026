---
const history = [
  {
    period: 'Aug 2025 – Sep 2025',
    title: 'Sansan, Inc. — Summer Internship',
    desc: 'Interned in the Data Intelligence EU MasterData group within the Technology Division.',
    type: 'intern',
  },
  {
    period: 'Oct 2023 –',
    title: 'PR TIMES, Inc. — Long-term Backend Internship',
    desc: 'Backend development in PHP. Used PHPStan, PHPUnit, BigQuery, etc.',
    type: 'intern',
  },
  {
    period: 'Apr 2023 –',
    title: 'Nagoya Institute of Technology — Dept. of Computer Science, Intelligent Information',
    desc: '',
    type: 'academic',
  },
  {
    period: 'Apr 2018 – Mar 2023',
    title: 'Toyota National College of Technology — Dept. of Information Engineering',
    desc: 'Dormitory committee leader (3 yrs), Student council vice president (3rd & 4th yr)',
    type: 'academic',
  },
  {
    period: 'March 10, 2003',
    title: 'Born',
    desc: 'Aichi, Japan',
    type: 'life',
  },
];
---

<section class="section bg-alt" id="history">
  <div class="container">
    <h2 class="section-title">History</h2>
    <div class="timeline__legend">
      <span class="legend-item legend-item--intern">Internship</span>
      <span class="legend-item legend-item--academic">Academic</span>
      <span class="legend-item legend-item--life">Life</span>
    </div>
    <ol class="timeline">
      {history.map((item) => (
        <li class="timeline__item">
          <div class={`timeline__dot timeline__dot--${item.type}`} aria-hidden="true"></div>
          <div class="timeline__content">
            <span class="timeline__period">{item.period}</span>
            <h3 class="timeline__title">{item.title}</h3>
            {item.desc && <p class="timeline__desc">{item.desc}</p>}
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .bg-alt {
    background: var(--surface);
  }

  .timeline__legend {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .legend-item::before {
    content: '';
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .legend-item--intern::before { background: #f59e0b; }
  .legend-item--academic::before { background: var(--accent); }
  .legend-item--life::before { background: #a78bfa; }

  .timeline {
    list-style: none;
    position: relative;
    padding-left: 2rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 0.66rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 2px;
    background: var(--border);
  }

  .timeline__item {
    position: relative;
    padding-bottom: 2.5rem;
  }

  .timeline__item:last-child {
    padding-bottom: 0;
  }

  .timeline__dot {
    position: absolute;
    left: -1.55rem;
    top: 0.45rem;
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .timeline__dot--intern   { background: #f59e0b; }
  .timeline__dot--academic { background: var(--accent); }
  .timeline__dot--life     { background: #a78bfa; }

  .timeline__period {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .timeline__title {
    font-size: 1.05rem;
    margin: 0.25rem 0 0.4rem;
  }

  .timeline__desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
  }
</style>
