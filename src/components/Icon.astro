---
import {
  siGithub,
  siX,
  siInstagram,
  siDiscord,
  siQiita,
  siZenn,
} from 'simple-icons';

interface Props {
  name: 'github' | 'x' | 'instagram' | 'linkedin' | 'discord' | 'qiita' | 'zenn' | 'prtimes' | 'sizu' | 'rss';
  size?: number;
  color?: string;
}

const { name, size = 20, color = 'currentColor' } = Astro.props;

const iconMap: Record<string, string> = {
  github: siGithub.path,
  x: siX.path,
  instagram: siInstagram.path,
  discord: siDiscord.path,
  qiita: siQiita.path,
  zenn: siZenn.path,
  // LinkedIn official path (viewBox 0 0 24 24)
  linkedin: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z',
  // PR TIMES: "P" shaped path (custom)
  prtimes: 'M4 4h6c3.31 0 6 2.69 6 6s-2.69 6-6 6H8v4H4V4zm4 8h2c1.1 0 2-.9 2-2s-.9-2-2-2H8v4z',
  // RSS standard icon
  rss: 'M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z',
};

const path = iconMap[name];
---

{name === 'sizu' ? (
  <img
    src="/sizu.svg"
    width={size}
    height={size}
    alt="Sizu"
    aria-hidden="true"
    style={`display:inline-block;vertical-align:middle;${color !== 'currentColor' ? `filter:brightness(0) invert(1)` : ''}`}
  />
) : path ? (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill={color}
    aria-hidden="true"
    role="img"
  >
    <path d={path} />
  </svg>
) : null}