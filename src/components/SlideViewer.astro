---
interface Props {
  pdf: string;
}

const { pdf } = Astro.props;
---

<div class="viewer" id="slide-viewer" data-pdf={pdf}>
  <div class="viewer__canvas-wrap">
    <canvas id="pdf-canvas"></canvas>
  </div>
  <div class="viewer__controls">
    <button id="btn-prev" class="viewer__btn" aria-label="前のページ" disabled>&#8592;</button>
    <span class="viewer__page-info">
      <span id="page-current">1</span> / <span id="page-total">—</span>
    </span>
    <button id="btn-next" class="viewer__btn" aria-label="次のページ">&#8594;</button>
    <button id="btn-fullscreen" class="viewer__btn viewer__btn--full" aria-label="フルスクリーン">&#x26F6;</button>
  </div>
</div>

<script>
  // pdf.js CDN
  const PDFJS_CDN = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.4.168/pdf.min.mjs';
  const WORKER_SRC = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.4.168/pdf.worker.min.mjs';

  const viewerEl = document.getElementById('slide-viewer') as HTMLElement;
  const canvas = document.getElementById('pdf-canvas') as HTMLCanvasElement;
  const btnPrev = document.getElementById('btn-prev') as HTMLButtonElement;
  const btnNext = document.getElementById('btn-next') as HTMLButtonElement;
  const btnFull = document.getElementById('btn-fullscreen') as HTMLButtonElement;
  const pageCurrentEl = document.getElementById('page-current') as HTMLElement;
  const pageTotalEl = document.getElementById('page-total') as HTMLElement;

  const pdfUrl = viewerEl.dataset.pdf ?? '';

  let pdfDoc: any = null;
  let currentPage = 1;
  let rendering = false;

  async function init() {
    const { getDocument, GlobalWorkerOptions } = await import(PDFJS_CDN);
    GlobalWorkerOptions.workerSrc = WORKER_SRC;
    pdfDoc = await getDocument(pdfUrl).promise;
    pageTotalEl.textContent = String(pdfDoc.numPages);
    renderPage(1);
  }

  async function renderPage(num: number) {
    if (rendering) return;
    rendering = true;
    currentPage = num;
    pageCurrentEl.textContent = String(num);
    btnPrev.disabled = num <= 1;
    btnNext.disabled = num >= pdfDoc.numPages;

    const page = await pdfDoc.getPage(num);
    const container = canvas.parentElement as HTMLElement;
    const containerWidth = container.clientWidth;
    const viewport = page.getViewport({ scale: 1 });
    const scale = containerWidth / viewport.width;
    const scaledViewport = page.getViewport({ scale });

    canvas.width = scaledViewport.width;
    canvas.height = scaledViewport.height;

    const ctx = canvas.getContext('2d') as CanvasRenderingContext2D;
    await page.render({ canvasContext: ctx, viewport: scaledViewport }).promise;
    rendering = false;
  }

  btnPrev.addEventListener('click', () => {
    if (currentPage > 1) renderPage(currentPage - 1);
  });

  btnNext.addEventListener('click', () => {
    if (pdfDoc && currentPage < pdfDoc.numPages) renderPage(currentPage + 1);
  });

  btnFull.addEventListener('click', () => {
    if (!document.fullscreenElement) {
      viewerEl.requestFullscreen();
    } else {
      document.exitFullscreen();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
      if (pdfDoc && currentPage < pdfDoc.numPages) renderPage(currentPage + 1);
    } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
      if (currentPage > 1) renderPage(currentPage - 1);
    }
  });

  // Swipe support
  let touchStartX = 0;
  viewerEl.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; });
  viewerEl.addEventListener('touchend', (e) => {
    const dx = e.changedTouches[0].clientX - touchStartX;
    if (Math.abs(dx) > 50) {
      if (dx < 0 && pdfDoc && currentPage < pdfDoc.numPages) renderPage(currentPage + 1);
      else if (dx > 0 && currentPage > 1) renderPage(currentPage - 1);
    }
  });

  // Resize
  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => renderPage(currentPage), 200);
  });

  init();
</script>

<style>
  .viewer {
    background: var(--slides-bg, #1a1a2e);
    border-radius: 8px;
    overflow: hidden;
    max-width: 900px;
    margin: 0 auto;
  }

  .viewer__canvas-wrap {
    width: 100%;
    background: #000;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 200px;
  }

  #pdf-canvas {
    display: block;
    width: 100%;
    height: auto;
  }

  .viewer__controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    padding: 0.75rem 1rem;
    background: var(--slides-surface, #232340);
    border-top: 1px solid var(--slides-border, #333366);
  }

  .viewer__btn {
    background: transparent;
    border: 1px solid var(--slides-border, #333366);
    color: var(--slides-text, #e0e0e0);
    border-radius: 4px;
    width: 2rem;
    height: 2rem;
    cursor: pointer;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, border-color 0.15s;
  }

  .viewer__btn:hover:not(:disabled) {
    border-color: var(--slides-accent, #7c8cf5);
    color: var(--slides-accent, #7c8cf5);
  }

  .viewer__btn:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .viewer__btn--full {
    margin-left: 0.5rem;
    font-size: 0.85rem;
  }

  .viewer__page-info {
    font-family: var(--slides-font-mono, monospace);
    font-size: 0.875rem;
    color: var(--slides-muted, #888);
    min-width: 5rem;
    text-align: center;
  }

  .viewer:fullscreen .viewer__canvas-wrap {
    height: calc(100vh - 3rem);
  }

  .viewer:fullscreen #pdf-canvas {
    width: auto;
    max-width: 100%;
    max-height: calc(100vh - 3rem);
    object-fit: contain;
  }
</style>
