---
interface Props {
  title: string;
  description?: string;
  publishedAt: string;
  tags?: string[];
  href: string;
}

const { title, description, publishedAt, tags = [], href } = Astro.props;
const dateStr = new Date(publishedAt).toLocaleDateString('ja-JP', {
  year: 'numeric', month: 'short', day: 'numeric',
});
---

<a href={href} class="blog-card">
  <div class="blog-card__badge">This Site</div>
  <h2 class="blog-card__title">{title}</h2>
  {description && <p class="blog-card__desc">{description}</p>}
  <div class="blog-card__footer">
    <time class="blog-card__date" datetime={publishedAt}>{dateStr}</time>
    {tags.length > 0 && (
      <div class="blog-card__tags">
        {tags.slice(0, 3).map(tag => <span class="tag">{tag}</span>)}
      </div>
    )}
  </div>
</a>

<style>
  .blog-card {
    display: block;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem;
    text-decoration: none;
    color: var(--text);
    transition: border-color 0.15s, transform 0.15s;
  }

  .blog-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .blog-card__badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    color: #fff;
    background: var(--accent);
    padding: 0.1em 0.5em;
    border-radius: 3px;
    margin-bottom: 0.5rem;
    letter-spacing: 0.03em;
  }

  .blog-card__title {
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }

  .blog-card__desc {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .blog-card__date {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .blog-card__tags {
    display: flex;
    gap: 0.3rem;
    flex-wrap: wrap;
  }
</style>
