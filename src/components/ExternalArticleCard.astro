---
import type { ExternalArticle } from '../lib/fetchArticles';

interface Props {
  article: ExternalArticle;
}

const { article } = Astro.props;
const dateStr = new Date(article.publishedAt).toLocaleDateString('ja-JP', {
  year: 'numeric', month: 'short', day: 'numeric',
});
const sourceLabel = article.source === 'zenn' ? 'Zenn' : article.source === 'qiita' ? 'Qiita' : 'PR TIMES';
const sourceColor = article.source === 'zenn' ? '#3EA8FF' : article.source === 'qiita' ? '#55c500' : '#E14D2A';
---

<a href={article.url} target="_blank" rel="noopener" class="ext-card">
  <div class="ext-card__badge" style={`background: ${sourceColor}`}>{sourceLabel}</div>
  <h2 class="ext-card__title">{article.title}</h2>
  {article.description && (
    <p class="ext-card__desc">{article.description}</p>
  )}
  <div class="ext-card__footer">
    <time class="ext-card__date" datetime={article.publishedAt}>{dateStr}</time>
    {article.tags && article.tags.length > 0 && (
      <div class="ext-card__tags">
        {article.tags.slice(0, 3).map(tag => <span class="tag">{tag}</span>)}
      </div>
    )}
  </div>
</a>

<style>
  .ext-card {
    display: block;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem;
    text-decoration: none;
    color: var(--text);
    transition: border-color 0.15s, transform 0.15s;
    position: relative;
  }

  .ext-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .ext-card__badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    color: #fff;
    padding: 0.1em 0.5em;
    border-radius: 3px;
    margin-bottom: 0.5rem;
    letter-spacing: 0.03em;
  }

  .ext-card__title {
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }

  .ext-card__desc {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ext-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .ext-card__date {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .ext-card__tags {
    display: flex;
    gap: 0.3rem;
    flex-wrap: wrap;
  }
</style>
